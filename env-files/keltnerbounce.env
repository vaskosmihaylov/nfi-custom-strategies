# KeltnerBounce (Longs) Strategy - External Port 8126
# Long-only variant with 3x leverage

# Bot Configuration
FREQTRADE__BOT_NAME=Vasko_KeltnerBounce
FREQTRADE__STRATEGY=KeltnerBounce

# Exchange Configuration
FREQTRADE__EXCHANGE__NAME=bybit
FREQTRADE__EXCHANGE__KEY=Your_Real_API_Key
FREQTRADE__EXCHANGE__SECRET=Your_Real_API_Secret
FREQTRADE__TRADING_MODE=futures
FREQTRADE__MARGIN_MODE=isolated

# Trading Configuration
FREQTRADE__DRY_RUN=true
FREQTRADE__DRY_RUN_WALLET=10000
FREQTRADE__STAKE_CURRENCY=USDT
FREQTRADE__STAKE_AMOUNT=unlimited
FREQTRADE__TRADABLE_BALANCE_RATIO=0.99
FREQTRADE__MAX_OPEN_TRADES=1

# API Server Configuration
FREQTRADE__API_SERVER__ENABLED=true
FREQTRADE__API_SERVER__LISTEN_IP_ADDRESS=0.0.0.0
FREQTRADE__API_SERVER__LISTEN_PORT=8080
FREQTRADE__API_SERVER__USERNAME=keltnerbounce_user
FREQTRADE__API_SERVER__PASSWORD=keltnerbounce_secure_password
FREQTRADE__API_SERVER__JWT_SECRET_KEY=KeltnerBounce_JWTSecretKey2026_v1
FREQTRADE__API_SERVER__WS_TOKEN=KeltnerBounce_WSToken2026_v1

# CORS Configuration (comma-separated, NOT JSON)
FREQTRADE__API_SERVER__CORS_ORIGINS=https://freq.gaiaderma.com,http://freq.gaiaderma.com
FREQTRADE__API_SERVER__FORWARDED_ALLOW_IPS="*"
